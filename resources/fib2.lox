fun fib(n) {
  var a = 0;
  var b = 1;

  for (var i = 0; i <= n; i = i + 1) {
    print a;
    var temp = a;
    a = b;
    b = temp + b;
  }
}

print "Input Number";
var input = to_number(read_line());

if (input == nil) {
  print "Invalid number";
} else {
  var start = clock();
  fib(input);
  print clock() - start;
}

